<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/Widget.AndroidBuilder.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/crashCardTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="?attr/colorError"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/crashCardStatus"
                style="@style/TextBodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorPrimary" />
        </LinearLayout>

        <TextView
            android:id="@+id/crashCardDetail"
            style="@style/TextBodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/crashCardLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input"
            android:fontFamily="monospace"
            android:padding="10dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crashCardAction"
            style="@style/Widget.AndroidBuilder.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_gravity="end"
            android:layout_marginTop="12dp"
            android:minWidth="96dp"
            android:textSize="13sp"
            android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
