<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/settingsToolbar"
        style="@style/Widget.AndroidBuilder.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        app:navigationContentDescription="@string/back"
        app:navigationIcon="@drawable/ic_back"
        app:subtitle="@string/app_tagline"
        app:title="@string/settings" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                style="@style/TextSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/model_configuration" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.AndroidBuilder.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.AndroidBuilder.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/language"
                        app:endIconMode="dropdown_menu">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/languageSpinner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.AndroidBuilder.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="@string/provider"
                        app:endIconMode="dropdown_menu">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/providerSpinner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.AndroidBuilder.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="@string/api_key_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/apiKeyInput"
                            style="@style/InputField"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.AndroidBuilder.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="@string/endpoint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/endpointInput"
                            style="@style/InputField"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textUri" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/modelLabel"
                        style="@style/TextSectionLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/model" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/deepseekModelLayout"
                        style="@style/Widget.AndroidBuilder.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:hint="@string/model"
                        android:visibility="gone"
                        app:endIconMode="dropdown_menu">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/deepseekModelSpinner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/minimaxModelLayout"
                        style="@style/Widget.AndroidBuilder.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:hint="@string/model"
                        android:visibility="gone"
                        app:endIconMode="dropdown_menu">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/minimaxModelSpinner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/modelInputLayout"
                        style="@style/Widget.AndroidBuilder.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:hint="@string/model">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/modelInput"
                            style="@style/InputField"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/saveSettingsButton"
                        style="@style/Widget.AndroidBuilder.Button.Filled"
                        android:layout_width="match_parent"
                        android:layout_marginTop="14dp"
                        android:text="@string/save_settings" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/TextSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/runtime_configuration" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.AndroidBuilder.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.AndroidBuilder.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/build_backend"
                        app:endIconMode="dropdown_menu">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/backendSpinner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.AndroidBuilder.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="@string/runtime_bootstrap_url">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/runtimeBootstrapUrlInput"
                            style="@style/InputField"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textUri" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/installBundledRuntimeButton"
                        style="@style/Widget.AndroidBuilder.Button.Filled"
                        android:layout_width="match_parent"
                        android:layout_marginTop="14dp"
                        android:text="@string/install_bundled_runtime" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/downloadRuntimeButton"
                        style="@style/Widget.AndroidBuilder.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="@string/download_runtime" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/refreshRuntimeStatusButton"
                        style="@style/Widget.AndroidBuilder.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="@string/refresh_runtime_status" />

                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.AndroidBuilder.Card.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">

                        <TextView
                            android:id="@+id/runtimeStatusText"
                            style="@style/TextBodyMedium"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/thirdPartyNoticesButton"
                style="@style/Widget.AndroidBuilder.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_marginTop="14dp"
                android:text="@string/third_party_notices" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/termuxSection"
                style="@style/Widget.AndroidBuilder.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/TextSectionLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/compatibility_mode" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/runTermuxSetupButton"
                        style="@style/Widget.AndroidBuilder.Button.Filled"
                        android:layout_width="match_parent"
                        android:layout_marginTop="10dp"
                        android:text="@string/run_termux_setup" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/requestTermuxPermissionButton"
                        style="@style/Widget.AndroidBuilder.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="@string/request_termux_permission" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/copyAdbGrantButton"
                        style="@style/Widget.AndroidBuilder.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="@string/copy_adb_grant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/copyTermuxBasicsButton"
                        style="@style/Widget.AndroidBuilder.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="@string/copy_termux_basics" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/copyBuildScriptButton"
                        style="@style/Widget.AndroidBuilder.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="@string/copy_build_script" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/copySetupScriptButton"
                        style="@style/Widget.AndroidBuilder.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="@string/copy_setup_script" />

                    <TextView
                        android:id="@+id/termuxHelp"
                        style="@style/TextBodyMedium"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
