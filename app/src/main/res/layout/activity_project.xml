<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/projectToolbar"
        style="@style/Widget.AndroidBuilder.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        app:navigationContentDescription="@string/back"
        app:navigationIcon="@drawable/ic_back" />

    <LinearLayout
        android:id="@+id/promptEditorPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <TextView
            style="@style/TextSectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/prompt_hint" />

        <EditText
            android:id="@+id/promptEditorInput"
            style="@style/PlainInputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:gravity="top|start"
            android:hint="@string/prompt_hint"
            android:imeOptions="actionNone|flagNoExtractUi"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="8"
            android:minLines="5"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            android:scrollbars="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/promptEditorCancelButton"
                style="@style/Widget.AndroidBuilder.Button.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="@string/cancel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/promptEditorSubmitButton"
                style="@style/Widget.AndroidBuilder.Button.Filled"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:text="@string/generate" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/projectContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp">

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.AndroidBuilder.Card.Filled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/statusText"
                style="@style/TextBodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/projectTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            app:tabIndicatorFullWidth="false"
            app:tabMode="fixed" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/designPanel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_module_panel"
                android:orientation="vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingBottom="10dp">

                <ListView
                    android:id="@+id/messageList"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="8dp"
                    android:paddingBottom="6dp" />

                <LinearLayout
                    android:id="@+id/designInputBlock"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurface"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_input"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:paddingTop="12dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="12dp">

                        <TextView
                            style="@style/TextSectionLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/prompt_hint" />

                        <EditText
                            android:id="@+id/promptInput"
                            style="@style/PlainInputField"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="top"
                            android:inputType="textMultiLine|textCapSentences"
                            android:maxLines="5"
                            android:minLines="3"
                            android:scrollbars="vertical" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/sendButton"
                        style="@style/Widget.AndroidBuilder.Button.Filled"
                        android:layout_width="match_parent"
                        android:layout_marginTop="10dp"
                        android:text="@string/generate"
                        app:icon="@drawable/ic_send" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/executePanel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_module_panel"
                android:orientation="vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingBottom="10dp"
                android:visibility="gone">

                <TextView
                    style="@style/TextSectionLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/plan_tasks" />

                <ListView
                    android:id="@+id/taskList"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="8dp"
                    android:paddingBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/showFilesButton"
                    style="@style/Widget.AndroidBuilder.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_marginTop="10dp"
                    android:text="@string/show_source_files"
                    app:icon="@drawable/ic_folder" />

                <LinearLayout
                    android:id="@+id/fileBrowserPanel"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/currentPathText"
                        style="@style/TextSectionLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <ListView
                        android:id="@+id/fileList"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="8dp"
                        android:layout_weight="1"
                        android:clipToPadding="false"
                        android:divider="@android:color/transparent"
                        android:dividerHeight="8dp"
                        android:paddingBottom="8dp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/executePlanButton"
                    style="@style/Widget.AndroidBuilder.Button.Filled"
                    android:layout_width="match_parent"
                    android:layout_marginTop="10dp"
                    android:text="@string/execute_plan"
                    app:icon="@drawable/ic_code" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/buildPanel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_module_panel"
                android:orientation="vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingBottom="10dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/TextSectionLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/build_log" />

                    <ProgressBar
                        android:id="@+id/buildProgress"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_marginEnd="8dp"
                        android:indeterminate="true" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/copyLogButton"
                        style="@style/Widget.AndroidBuilder.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/copy_log"
                        android:textSize="12sp"
                        app:icon="@drawable/ic_copy" />
                </LinearLayout>

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:fillViewport="true">

                    <TextView
                        android:id="@+id/buildLogContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_log_md3"
                        android:fontFamily="monospace"
                        android:lineSpacingExtra="2dp"
                        android:padding="12dp"
                        android:textColor="@color/colorInverseOnSurface"
                        android:textSize="12sp" />
                </ScrollView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buildButton"
                        style="@style/Widget.AndroidBuilder.Button.Filled"
                        android:layout_width="0dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:text="@string/build"
                        app:icon="@drawable/ic_build" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/installButton"
                        style="@style/Widget.AndroidBuilder.Button.Outlined"
                        android:layout_width="0dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:text="@string/install"
                        app:icon="@drawable/ic_install" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
