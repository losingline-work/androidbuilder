<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:id="@+id/projectContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/projectToolbar"
            style="@style/Widget.AndroidBuilder.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?attr/actionBarSize"
            app:navigationContentDescription="@string/back"
            app:navigationIcon="@drawable/ic_back" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginStart="14dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="14dp"
            android:layout_weight="1"
            android:background="@drawable/bg_module_panel"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/milestoneStrip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:lineSpacingExtra="3dp"
                android:padding="10dp"
                android:textColor="?attr/colorOnSurface"
                android:textSize="12sp"
                android:visibility="gone" />

            <ListView
                android:id="@+id/messageList"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:divider="@android:color/transparent"
                android:dividerHeight="8dp"
                android:paddingBottom="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="14dp">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="false"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/executePlanButton"
                        style="@style/Widget.AndroidBuilder.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:minWidth="0dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="@string/execute_plan"
                        android:textSize="12sp"
                        app:icon="@drawable/ic_code" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buildButton"
                        style="@style/Widget.AndroidBuilder.Button.Filled"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:minWidth="0dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="@string/build"
                        android:textSize="12sp"
                        app:icon="@drawable/ic_build" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/repairButton"
                        style="@style/Widget.AndroidBuilder.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:minWidth="0dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="@string/repair_build"
                        android:textSize="12sp"
                        app:icon="@drawable/ic_code" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/installButton"
                        style="@style/Widget.AndroidBuilder.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:minWidth="0dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="@string/install"
                        android:textSize="12sp"
                        app:icon="@drawable/ic_install" />
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/designInputBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:gravity="bottom"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingTop="10dp"
                android:paddingEnd="8dp"
                android:paddingBottom="10dp">

                <EditText
                    android:id="@+id/promptInput"
                    style="@style/PlainInputField"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:gravity="top|start"
                    android:hint="@string/prompt_hint"
                    android:imeOptions="actionNone|flagNoExtractUi"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLines="4"
                    android:minLines="1"
                    android:scrollbars="vertical" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/sendButton"
                    style="@style/Widget.AndroidBuilder.Button.Filled"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:minWidth="0dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="@string/generate"
                    app:icon="@drawable/ic_send" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/fileDrawerScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/fileBrowserPanel"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="?attr/colorSurface"
        android:elevation="10dp"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="18dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/TextSectionLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/source_files"
                android:textColor="?attr/colorPrimary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/closeFilesButton"
                style="@style/Widget.AndroidBuilder.Button.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="@string/close"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/currentPathText"
            style="@style/TextBodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <ListView
            android:id="@+id/fileList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"
            android:paddingBottom="8dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/logQueryPanel"
        android:layout_width="340dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="?attr/colorSurface"
        android:elevation="10dp"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="18dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/TextSectionLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/log_query"
                android:textColor="?attr/colorPrimary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/closeLogsButton"
                style="@style/Widget.AndroidBuilder.Button.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="@string/close"
                android:textSize="12sp" />
        </LinearLayout>

        <EditText
            android:id="@+id/logSearchInput"
            style="@style/PlainInputField"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="@string/search_logs"
            android:imeOptions="actionSearch|flagNoExtractUi"
            android:inputType="text"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:singleLine="true" />

        <TextView
            android:id="@+id/logResultCount"
            style="@style/TextBodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/logDurationSummary"
            style="@style/TextBodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="?attr/colorPrimary"
            android:textSize="12sp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/exportLogsButton"
            style="@style/Widget.AndroidBuilder.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/export_log"
            android:textSize="12sp"
            app:icon="@drawable/ic_export" />

        <ListView
            android:id="@+id/logResultList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"
            android:paddingBottom="8dp" />
    </LinearLayout>
</FrameLayout>
