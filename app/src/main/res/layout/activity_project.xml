<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/back"
            android:padding="10dp"
            android:src="@drawable/ic_back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/projectTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ink"
                android:textSize="23sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:background="@drawable/bg_status"
                android:padding="8dp"
                android:textColor="@color/brandDark"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <ListView
        android:id="@+id/messageList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:paddingBottom="6dp" />

    <TextView
        style="@style/TextSectionLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/build_log" />

    <TextView
        android:id="@+id/logText"
        android:layout_width="match_parent"
        android:layout_height="104dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_log"
        android:fontFamily="monospace"
        android:padding="10dp"
        android:scrollbars="vertical"
        android:textColor="#D9E7E3"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/promptInput"
        style="@style/InputField"
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:layout_marginTop="10dp"
        android:gravity="top"
        android:hint="@string/prompt_hint"
        android:inputType="textMultiLine|textCapSentences" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="9dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/sendButton"
            style="@style/ButtonPrimary"
            android:layout_width="0dp"
            android:layout_marginEnd="7dp"
            android:layout_weight="1"
            android:text="@string/generate" />

        <Button
            android:id="@+id/buildButton"
            style="@style/ButtonSecondary"
            android:layout_width="0dp"
            android:layout_marginStart="1dp"
            android:layout_marginEnd="7dp"
            android:layout_weight="1"
            android:text="@string/build" />

        <Button
            android:id="@+id/installButton"
            style="@style/ButtonSecondary"
            android:layout_width="0dp"
            android:layout_marginStart="1dp"
            android:layout_weight="1"
            android:text="@string/install" />
    </LinearLayout>
</LinearLayout>
